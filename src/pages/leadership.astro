---
import BaseLayout from "../layouts/BaseLayout.astro";
import Navbar from "../components/Navbar.astro";
import Footer from "../components/Footer.astro";
import { Icon } from "astro-icon/components";
import leadership from "../data/leadership.json";
import "../styles/leadership.css";

const getTypeIcon = (type: string) => {
  const icons: Record<string, string> = {
    conference: "lucide:mic-2",
    workshop: "lucide:code",
    panel: "lucide:users",
    hackathon: "lucide:rocket",
    series: "lucide:calendar",
  };
  return icons[type] || "lucide:star";
};

const getStatusClass = (status: string) => {
  return status === "ongoing" ? "lead__status--ongoing" : "lead__status--completed";
};
---

<BaseLayout title="Leadership | icypinks" description="Leadership, events & community work">
  <Navbar />

  <main class="lead">
    <div class="lead__container">

      <!-- Header -->
      <header class="lead__header">
        <div class="lead__breadcrumb">
          <a href="/" class="lead__breadcrumb-link">~</a>
          <span class="lead__breadcrumb-sep">/</span>
          <span class="lead__breadcrumb-current">{leadership.title}</span>
        </div>

        <div class="lead__title-row">
          <div class="lead__title-left">
            <span class="lead__prompt">user@portfolio:~$</span>
            <h1 class="lead__title">ls ./{leadership.title}</h1>
          </div>
          <div class="lead__title-right">
            <span class="lead__file-count">{leadership.events.length} events</span>
          </div>
        </div>

        <p class="lead__subtitle"># {leadership.subtitle}</p>
        <p class="lead__intro">{leadership.intro}</p>
      </header>

      <!-- Stats Row -->
      <div class="lead__stats">
        {leadership.stats.map((stat) => (
          <div class="lead__stat">
            <span class="lead__stat-value">{stat.value}</span>
            <span class="lead__stat-label">{stat.label}</span>
          </div>
        ))}
      </div>

      <!-- Communities -->
      <section class="lead__communities">
        <h2 class="lead__section-title">
          <span class="lead__section-prompt">$</span>
          cat communities.md
        </h2>

        <div class="lead__communities-grid">
          {leadership.communities.map((c) => (
            <a href={c.link} target="_blank" rel="noreferrer" class="lead__community">
              <div class="lead__community-top">
                <Icon name="lucide:users" />
                <span class="lead__community-role">{c.role}</span>
              </div>
              <h3 class="lead__community-name">{c.name}</h3>
              <span class="lead__community-period">{c.period}</span>
            </a>
          ))}
        </div>
      </section>

      <!-- Events Grid -->
      <section class="lead__events">
        <h2 class="lead__section-title">
          <span class="lead__section-prompt">$</span>
          find ./events -type f
        </h2>

        <div class="lead__events-grid">
          {leadership.events.map((event, i) => (
            <article class="lead__event">
              <!-- Window Top -->
              <div class="lead__event-top">
                <div class="lead__dots">
                  <span class="dot dot--r"></span>
                  <span class="dot dot--y"></span>
                  <span class="dot dot--g"></span>
                </div>
                <span class="lead__event-file">event_{String(i + 1).padStart(2, '0')}.md</span>
                <span class={`lead__status ${getStatusClass(event.status)}`}>
                  {event.status}
                </span>
              </div>

              <!-- Event Body -->
              <div class="lead__event-body">
                <!-- Type & Date -->
                <div class="lead__event-meta">
                  <span class="lead__event-type">
                    <Icon name={getTypeIcon(event.type)} />
                    {event.type}
                  </span>
                  <span class="lead__event-date">{event.date}</span>
                </div>

                <!-- Title & Role -->
                <h3 class="lead__event-name">{event.name}</h3>
                <p class="lead__event-role">{event.role}</p>

                <!-- Description -->
                <p class="lead__event-desc">{event.description}</p>

                <!-- Highlights -->
                <div class="lead__event-highlights">
                  <span class="lead__highlights-label"># highlights</span>
                  <ul class="lead__highlights-list">
                    {event.highlights.map((h) => (
                      <li class="lead__highlight">
                        <span class="lead__highlight-marker">→</span>
                        {h}
                      </li>
                    ))}
                  </ul>
                </div>

                <!-- Footer -->
                <div class="lead__event-footer">
                  <div class="lead__event-info">
                    <span class="lead__event-location">
                      <Icon name="lucide:map-pin" />
                      {event.location}
                    </span>
                    <span class="lead__event-attendees">
                      <Icon name="lucide:users" />
                      {event.attendees}+
                    </span>
                  </div>

                  <div class="lead__event-tags">
                    {event.tags.map((tag) => (
                      <span class="lead__tag">{tag}</span>
                    ))}
                  </div>
                </div>
              </div>
            </article>
          ))}
        </div>
      </section>

      <!-- Back Link -->
      <div class="lead__back">
        <a href="/" class="lead__back-link">
          <span class="lead__back-prompt">$</span>
          <span class="lead__back-cmd">cd ~</span>
          <span class="lead__back-text">// back to home</span>
        </a>
      </div>

    </div>
  </main>

  <Footer />
</BaseLayout>