---
import BaseLayout from "../layouts/BaseLayout.astro";
import Navbar from "../components/Navbar.astro";
import Footer from "../components/Footer.astro";
---
<BaseLayout title="Contact | icywest.dev" description="Contact route test">
  <Navbar />

  <main>
    <section class="container">
      <div class="card">
        <h1 style="margin:0 0 6px;">Contact</h1>
        <p class="muted" style="margin:0 0 14px;">
          Placeholder contact section. Replace with your real links later.
        </p>

        <div style="display:grid;gap:10px;max-width:520px;">
          <div class="card" style="padding:12px;">
            <div class="muted" style="font-size:12px;">Email</div>
            <div style="font-weight:700;">hello@example.com</div>
          </div>
          <div class="card" style="padding:12px;">
            <div class="muted" style="font-size:12px;">Social</div>
            <div style="font-weight:700;">GitHub • LinkedIn</div>
          </div>
        </div>
      </div>
    </section>
  </main>

  <Footer />
</BaseLayout>
