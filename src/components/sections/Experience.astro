---
import experience from "../../data/experience.json";
import { Icon } from "astro-icon/components";

const getStatusColor = (period: string) => {
  if (period.includes("2025")) return "active";
  if (period.includes("2024")) return "recent";
  return "past";
};
---

<section id="experience" class="exp">
  <div class="exp__container">
    <!-- Header -->
    <header class="exp__header">
      <div class="exp__title">
        <span class="exp__prompt">icy@portfolio:~$</span>
        <h2>cat experience.log</h2>
      </div>
      <div class="exp__rule"></div>
    </header>

    <!-- Terminal Window -->
    <div class="exp__terminal" x-data="{ active: 'program-leader' }">
      
      <!-- Sidebar Navigation -->
      <aside class="exp__sidebar">
        <nav class="exp__nav">
          {experience.map((role, i) => (
            <button
              class="exp__tab"
              :class={`{ 'exp__tab--active': active === '${role.key}' }`}
              @click={`active = '${role.key}'`}
            >
              <span class="exp__tab-index">0{i + 1}</span>
              <div class="exp__tab-content">
                <span class="exp__tab-title">{role.title}</span>
                <span class="exp__tab-org">{role.org}</span>
              </div>
              <span class="exp__tab-arrow">→</span>
            </button>
          ))}
        </nav>
      </aside>

      <!-- Main Content Panel -->
      <div class="exp__main">
        <div class="exp__main-top">
          <div class="exp__dots">
            <span class="dot dot--r"></span>
            <span class="dot dot--y"></span>
            <span class="dot dot--g"></span>
          </div>
          <span class="exp__main-title">~/experience</span>
          <div class="exp__main-actions">
            <Icon name="lucide:terminal" />
          </div>
        </div>

        <div class="exp__panels">
          {experience.map((role) => (
            <article
              class="exp__panel"
              x-show={`active === '${role.key}'`}
              x-cloak
            >
              <!-- Command prompt -->
              <div class="exp__cmd">
                <span class="exp__cmd-prompt">$</span>
                <span class="exp__cmd-text">{role.cmd}</span>
                <span class="exp__cmd-cursor">▋</span>
              </div>

              <!-- Role header -->
              <header class="exp__role-header">
                <h3 class="exp__role-title">{role.title}</h3>
                <p class="exp__role-subtitle">{role.subtitle}</p>
              </header>

              <!-- Meta info -->
              <div class="exp__meta">
                <span class="exp__meta-item">
                  <Icon name="lucide:building-2" />
                  {role.org}
                </span>
                <span class="exp__meta-divider">│</span>
                <span class="exp__meta-item">
                  <Icon name="lucide:calendar" />
                  {role.period}
                </span>
                <span class="exp__meta-divider">│</span>
                <span class={`exp__status exp__status--${getStatusColor(role.period)}`}>
                  <span class="exp__status-dot"></span>
                  {getStatusColor(role.period)}
                </span>
              </div>

              <!-- Bullets -->
              <ul class="exp__list">
                {role.bullets.map((bullet) => (
                  <li class="exp__list-item">
                    <span class="exp__list-marker">→</span>
                    <span class="exp__list-text">{bullet}</span>
                  </li>
                ))}
              </ul>

              <!-- Skills -->
              <div class="exp__skills">
                <span class="exp__skills-label"># tags:</span>
                {role.skills.map((skill) => (
                  <span class="exp__skill">{skill}</span>
                ))}
              </div>
            </article>
          ))}
        </div>
      </div>
    </div>
  </div>
</section>

<script src="https://unpkg.com/alpinejs@3.x.x/dist/cdn.min.js" defer></script>