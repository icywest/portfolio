---
import "../../styles/global.css";
import projects from "../../data/projects.json";
import { Icon } from "astro-icon/components";
import { withBase } from "../../utils/withBase";

// Terminal commands based on primary tech
const getTerminalCmd = (stack: string[], name: string) => {
  const primary = stack[0]?.toLowerCase() || "";
  const slug = name.toLowerCase().replace(/\s+/g, "-");
  
  if (primary.includes("react") || primary.includes("expo")) return `npm run dev`;
  if (primary.includes("node")) return `node server.js`;
  if (primary.includes("python")) return `python main.py`;
  if (primary.includes("full-stack")) return `docker-compose up`;
  return `cd ${slug}`;
};

// More natural prompts
const getPrompt = (index: number) => {
  const prompts = [
    { user: "dev", path: "~/code" },
    { user: "user", path: "~/projects" },
    { user: "admin", path: "~/workspace" },
    { user: "dev", path: "~/apps" },
    { user: "root", path: "/var/www" },
    { user: "dev", path: "~/src" },
  ];
  return prompts[index % prompts.length];
};

---

<section id="projects" class="projects">
  <header class="projects__header">
    <h1>projects</h1>
    <p class="muted">
      # a few things i've developed (by my own and in teams)
    </p>
  </header>

  <div class="projects__grid">
    {projects.map((p, i) => {
      const prompt = getPrompt(i);
      const cmd = getTerminalCmd(p.stack, p.name);
      
      return (
        <a
          class="win"
          href={p.href}
          target="_blank"
          rel="noreferrer"
          data-accent={p.accent}
        >
          <div class="win__top">
            <div class="win__dots">
              <span class="dot dot--r" />
              <span class="dot dot--y" />
              <span class="dot dot--g" />
            </div>

            <div class="win__title">{prompt.user}@icy: {prompt.path}</div>

            <div class="win__badge">
              <Icon name="lucide:github" />
            </div>
          </div>

          {p.image && (
            <div class="win__image">
              <img src={withBase(p.image)} alt={p.name} />
            </div>
          )}

          <div class="win__body">
            <div class="win__prompt">
              <span>$</span> {cmd}
            </div>
            
            <h3 class="win__name">{p.name}</h3>
            <p class="win__desc">{p.tagline}</p>

            <div class="win__stack">
              {p.stack.map((t) => (
                <span class="pill">{t}</span>
              ))}
            </div>
          </div>

          <div class="win__footer">
            <div class="win__footer-left">
              <span>{p.stack.length} {p.stack.length === 1 ? "tech" : "techs"}</span>
            </div>
            <span class="win__arrow">view source →</span>
          </div>
        </a>
      );
    })}
  </div>
</section>
