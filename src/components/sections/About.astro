---
import about from "../../data/about.json";
import { Icon } from "astro-icon/components";

const getCategoryIcon = (category: string) => {
  const icons: Record<string, string> = {
    lang: "lucide:code",
    frontend: "lucide:layout",
    backend: "lucide:server",
    data: "lucide:database",
    ml: "lucide:brain",
  };
  return icons[category] || "lucide:terminal";
};
---

<section id="about" class="abt">
  <div class="abt__container">
    <!-- Header -->
    <header class="abt__header">
      <div class="abt__title">
        <span class="abt__prompt">icy@portfolio:~$</span>
        <h2>cat about.md</h2>
      </div>
      <div class="abt__rule"></div>
    </header>

    <!-- Terminal Grid -->
    <div class="abt__grid">
      
      <!-- Main Content Window -->
      <div class="abt__main">
        <div class="abt__window">
          <div class="abt__window-top">
            <div class="abt__dots">
              <span class="dot dot--r"></span>
              <span class="dot dot--y"></span>
              <span class="dot dot--g"></span>
            </div>
            <span class="abt__window-title">~/about/readme.md</span>
            <div class="abt__window-actions">
              <Icon name="lucide:file-text" />
            </div>
          </div>

          <div class="abt__window-body">
            <!-- File header -->
            <div class="abt__file-header">
              <span class="abt__file-comment"># whoami</span>
            </div>

            <!-- Bio paragraphs -->
            <div class="abt__bio">
              {about.bio.map((paragraph, i) => (
                <p class="abt__bio-p" set:html={paragraph} />
              ))}
            </div>

            <!-- Divider -->
            <div class="abt__divider">
              <span>---</span>
            </div>

            <!-- Tech section -->
            <div class="abt__tech">
              <span class="abt__file-comment"># tech_stack</span>
              
              <div class="abt__tech-grid">
                {about.tech.map((t) => (
                  <div class="abt__tech-item">
                    <Icon name={getCategoryIcon(t.category)} />
                    <span>{t.name}</span>
                  </div>
                ))}
              </div>
            </div>

            <!-- CTA -->
            <div class="abt__cta">
              <a href={about.cta.href} class="abt__cta-btn">
                <span class="abt__cta-prompt">$</span>
                <span>cd {about.cta.href}</span>
                <span class="abt__cta-comment">// {about.cta.text}</span>
              </a>
            </div>
          </div>
        </div>
      </div>

      <!-- Sidebar - Photo + Info -->
      <aside class="abt__sidebar">
        <!-- Photo Window -->
        <div class="abt__photo-window">
          <div class="abt__window-top">
            <div class="abt__dots">
              <span class="dot dot--r"></span>
              <span class="dot dot--y"></span>
              <span class="dot dot--g"></span>
            </div>
            <span class="abt__window-title">avatar.svg</span>
            <div class="abt__window-actions">
              <Icon name="lucide:image" />
            </div>
          </div>
          <div class="abt__photo-body">
            <img src={about.imgSrc} alt={`Portrait of ${about.name}`} loading="lazy" />
          </div>
        </div>

        <!-- Info Card -->
        <div class="abt__info-window">
          <div class="abt__window-top">
            <div class="abt__dots">
              <span class="dot dot--r"></span>
              <span class="dot dot--y"></span>
              <span class="dot dot--g"></span>
            </div>
            <span class="abt__window-title">info.json</span>
            <div class="abt__window-actions">
              <Icon name="lucide:braces" />
            </div>
          </div>
          <div class="abt__info-body">
            <pre class="abt__json"><code>{`{`}
  <span class="json-key">"name"</span>: <span class="json-string">"{about.name}"</span>,
  <span class="json-key">"role"</span>: <span class="json-string">"{about.role}"</span>,
  <span class="json-key">"location"</span>: <span class="json-string">"{about.location}"</span>,
  <span class="json-key">"status"</span>: <span class="json-string">"{about.status}"</span>
{`}`}</code></pre>
            <div class="abt__status">
              <span class="abt__status-dot"></span>
              <span>{about.status}</span>
            </div>
          </div>
        </div>
      </aside>
    </div>
  </div>
</section>