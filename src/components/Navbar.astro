---
import { Icon } from "astro-icon/components";
import nav from "../data/navigation.json";
import logo from "../assets/images/icylogo.svg";

const homeHref = import.meta.env.BASE_URL;
---

<header class="nav">
  <div class="nav__inner">
    
    <!-- Left: Brand + Links -->
    <div class="nav__left">
      
      <!-- Logo/Brand -->
      <a href={homeHref} class="nav__brand">
        <img src={logo.src} alt={nav.brand.name} class="nav__logo" />
        <span class="nav__name">
          <span class="nav__prompt">~</span>/{nav.brand.name}
        </span>
      </a>

      <!-- Divider -->
      <span class="nav__divider">│</span>

      <!-- Navigation Links -->
      <nav class="nav__links">
        {nav.links.map((link) => {
          const href = link.href.startsWith("#")
            ? `${import.meta.env.BASE_URL}${link.href}`
            : link.href;

          return (
            <a href={href} class="nav__link">
              <span class="nav__link-cmd">{link.cmd}</span>
              <span class="nav__link-label">{link.label}</span>
            </a>
          );
        })}

      </nav>
    </div>

    <!-- Right: Social + Status -->
    <div class="nav__right">
      
      <!-- Status indicator -->
      <div class="nav__status">
        <span class="nav__status-dot"></span>
        <span class="nav__status-text">online</span>
      </div>

      <!-- Divider -->
      <span class="nav__divider">│</span>

      <!-- Social Icons -->
      <div class="nav__social">
        {nav.social.map((s) => (
          <a 
            href={s.href} 
            target="_blank" 
            rel="noreferrer"
            class="nav__social-link"
            aria-label={s.label}
          >
            <Icon name={s.icon} />
          </a>
        ))}
      </div>
    </div>

    <!-- Mobile Menu Toggle -->
    <button class="nav__toggle" aria-label="Toggle menu" id="nav-toggle">
      <span class="nav__toggle-bar"></span>
      <span class="nav__toggle-bar"></span>
      <span class="nav__toggle-bar"></span>
    </button>

  </div>

  <!-- Mobile Menu -->
  <div class="nav__mobile" id="nav-mobile">
    <div class="nav__mobile-inner">
      {nav.links.map((link, i) => {
        const href = link.href.startsWith("#")
          ? `${import.meta.env.BASE_URL}${link.href}`
          : link.href;

        return (
          <a href={href} class="nav__mobile-link">
            <span class="nav__mobile-index">0{i + 1}</span>
            <span class="nav__mobile-cmd">$ {link.cmd}</span>
            <span class="nav__mobile-label">{link.label}</span>
          </a>
        );
      })}
      <div class="nav__mobile-social">
        {nav.social.map((s) => (
          <a 
            href={s.href} 
            target="_blank" 
            rel="noreferrer"
            class="nav__mobile-social-link"
          >
            <Icon name={s.icon} />
            <span>{s.label}</span>
          </a>
        ))}
      </div>
    </div>
  </div>
</header>

<script is:inline>
  const initNavbar = () => {
    const toggle = document.getElementById("nav-toggle");
    const mobile = document.getElementById("nav-mobile");

    if (!(toggle instanceof HTMLButtonElement) || !(mobile instanceof HTMLElement)) {
      return;
    }

    toggle.addEventListener("click", () => {
      mobile.classList.toggle("nav__mobile--open");
      toggle.classList.toggle("nav__toggle--active");
    });

    document.querySelectorAll(".nav__mobile-link").forEach((link) => {
      link.addEventListener("click", () => {
        mobile.classList.remove("nav__mobile--open");
        toggle.classList.remove("nav__toggle--active");
      });
    });
  };

  if (document.readyState === "loading") {
    document.addEventListener("DOMContentLoaded", initNavbar, { once: true });
  } else {
    initNavbar();
  }
</script>
