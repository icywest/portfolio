---
import { Icon } from "astro-icon/components";

const links = [
  { href: "/about", label: "About", icon: "lucide:user" },
  { href: "/experience", label: "Experience", icon: "lucide:briefcase" },
  { href: "/projects", label: "Projects", icon: "lucide:folder" },
];
---


<header style="border-bottom:1px solid rgba(127,127,127,.25);">
  <div
    style="
      display:flex;
      align-items:center;
      justify-content:space-between;
      padding:14px 16px;
      gap:24px;
    "
  >
    <!-- LEFT: brand + nav -->
    <div style="display:flex;align-items:center;gap:24px;">
      <a href="/" style="font-weight:700;">
        Cynthia West <span style="opacity:.6;">| Portfolio</span>
      </a>

      <nav
        class="menu"
        aria-label="Main menu"
        style="display:flex;gap:16px;font-weight:600;"
      >
        {links.map((l) => (
          <a href={l.href}>{l.label}</a>
        ))}
      </nav>
    </div>

    <!-- RIGHT: actions -->
    <div style="display:flex;align-items:center;gap:14px;">
      <a
        href="https://linkedin.com/in/icywest"
        target="_blank"
        aria-label="LinkedIn"
        style="display:flex;align-items:center;"
      >
        <Icon name="lucide:linkedin" size="18" />
      </a>

      <a
        href="https://github.com/icywest"
        target="_blank"
        aria-label="GitHub"
        style="display:flex;align-items:center;"
      >
        <Icon name="lucide:github" size="18" />
      </a>

      <a
        href="mailto:icynwest@gmail.com"
        aria-label="Email"
        style="display:flex;align-items:center;"
      >
        <Icon name="lucide:mail" size="18" />
      </a>

    </div>
  </div>
</header>
