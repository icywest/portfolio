---
const links = [
  { href: "/about", label: "About" },
  { href: "/experience", label: "Experience" },
  { href: "/projects", label: "Projects" },
];
---

<header style="border-bottom:1px solid rgba(127,127,127,.25);">
  <div
    style="
      display:flex;
      align-items:center;
      justify-content:space-between;
      padding:14px 16px;
      gap:24px;
    "
  >
    <!-- LEFT: brand + nav -->
    <div style="display:flex;align-items:center;gap:24px;">
      <a href="/" style="font-weight:700;">
        Cynthia West <span style="opacity:.6;">| Portfolio</span>
      </a>

      <nav
        class="menu"
        aria-label="Main menu"
        style="display:flex;gap:16px;font-weight:600;"
      >
        {links.map((l) => (
          <a href={l.href}>{l.label}</a>
        ))}
      </nav>
    </div>

    <!-- RIGHT: actions -->
    <div style="display:flex;align-items:center;gap:14px;">
      <a
        href="https://linkedin.com/in/yourprofile"
        target="_blank"
        aria-label="LinkedIn"
      >
        LinkedIn
      </a>

       <a
        href="https://linkedin.com/in/yourprofile"
        target="_blank"
        aria-label="GitHub"
      >
        Github
      </a>

      <a
        href="mailto:youremail@example.com"
        aria-label="Email"
      >
        @
      </a>

      <a
        href="/contact"
        style="
          padding:6px 12px;
          border:1px solid rgba(127,127,127,.4);
          border-radius:6px;
          font-weight:600;
        "
      >
        Message
      </a>
    </div>
  </div>
</header>
